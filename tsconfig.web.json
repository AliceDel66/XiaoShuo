  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.web.tsbuildinfo",
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx",
    "src/shared/**/*.ts"
  ]
